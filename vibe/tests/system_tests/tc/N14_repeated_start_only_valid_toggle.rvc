# N14: Repeated start in StandbyMode/NormalMode follows only valid toggle behavior.
power
start
expect_mode NormalMode
expect_motor on
expect_cleaner on
start
expect_mode StandbyMode
expect_motor off
expect_cleaner off
start
expect_mode NormalMode
expect_motor on
expect_cleaner on
start
expect_mode StandbyMode
expect_motor off
expect_cleaner off
expect_boost off
