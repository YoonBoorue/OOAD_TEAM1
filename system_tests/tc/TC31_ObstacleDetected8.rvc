# TC31 : ObstacleDetected8
# Precondition : NormalMode, forward=true
# Action : left + right obstacle detected, front clear
# Expected : no change, keep moving forward
power
start
expect mode NormalMode
expect motorForward true
expect motorDirection FRONT
obstacle 0 1 1
expect mode NormalMode
expect cleaner on
expect motor moving
expect motorForward true
expect motorDirection FRONT
exit
