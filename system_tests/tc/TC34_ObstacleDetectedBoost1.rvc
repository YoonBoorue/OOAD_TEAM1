# TC34 : ObstacleDetectedBoost1
# Related normal-mode case : TC24_ObstacleDetected1
# Precondition : BoostMode, forward=true/false
# Action : front obstacle detected, left/right clear
# Expected : BoostMode 유지, CleanerDriver mode=boost 유지, turnLeft, forward=true

# Case A: forward=true
power
start
dust
expect mode BoostMode
expect cleaner on
expect cleanerMode boost
expect motorForward true
expect motorDirection FRONT
obstacle 1 0 0
expect mode BoostMode
expect cleaner on
expect cleanerMode boost
expect motor moving
expect motorForward true
expect motorDirection LEFT

# Reset
power
power
start
dust
expect mode BoostMode
expect cleaner on
expect cleanerMode boost

# Case B: forward=false
obstacle 1 1 1
expect mode BoostMode
expect cleanerMode boost
expect motorForward false
obstacle 1 0 0
expect mode BoostMode
expect cleaner on
expect cleanerMode boost
expect motor moving
expect motorForward true
expect motorDirection LEFT
exit
