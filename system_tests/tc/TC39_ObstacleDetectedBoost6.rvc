# TC39 : ObstacleDetectedBoost6
# Related normal-mode case : TC29_ObstacleDetected6
# Precondition : BoostMode, forward=true/false
# Action : front + right obstacle detected, left clear
# Expected : BoostMode 유지, CleanerDriver mode=boost 유지, turnLeft, forward=true

# Case A: forward=true
power
start
dust
expect mode BoostMode
expect cleaner on
expect cleanerMode boost
expect motorForward true
expect motorDirection FRONT
obstacle 1 0 1
expect mode BoostMode
expect cleaner on
expect cleanerMode boost
expect motor moving
expect motorForward true
expect motorDirection LEFT

# Reset
power
power
start
dust
expect mode BoostMode
expect cleaner on
expect cleanerMode boost

# Case B: forward=false
obstacle 1 1 1
expect mode BoostMode
expect cleanerMode boost
expect motorForward false
obstacle 1 0 1
expect mode BoostMode
expect cleaner on
expect cleanerMode boost
expect motor moving
expect motorForward true
expect motorDirection LEFT
exit
