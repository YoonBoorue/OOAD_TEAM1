# TC30 : ObstacleDetected7
# Precondition : NormalMode, forward=true/false
# Action : front + left obstacle detected, right clear
# Expected : turnRight, moveDirection changed to RIGHT, then forward=true

# Case A: forward=true
power
start
expect mode NormalMode
expect motorForward true
expect motorDirection FRONT
obstacle 1 1 0
expect mode NormalMode
expect cleaner on
expect motor moving
expect motorForward true
expect motorDirection RIGHT

# Reset
power
power
start

# Case B: forward=false
obstacle 1 1 1
expect motorForward false
obstacle 1 1 0
expect mode NormalMode
expect cleaner on
expect motor moving
expect motorForward true
expect motorDirection RIGHT
exit
